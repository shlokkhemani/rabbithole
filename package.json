{
  "name": "rabbithole",
  "version": "0.1.0",
  "type": "module",
  "description": "An infinite canvas for learning. Start from a document, select text, ask, and the answer branches out as a child document. Recurse forever.",
  "license": "MIT",
  "author": "Shlok Khemani",
  "homepage": "https://rabbithole.ing",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shlokkhemani/rabbithole.git"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:publish": "node scripts/build-publish.mjs",
    "check:dist": "node scripts/check-dist.mjs",
    "check:purity": "node scripts/check-ui-purity.mjs",
    "check:types": "tsc --noEmit",
    "test": "npm run test:stage1 && npm run test:stage2 && npm run test:stage3 && npm run test:stage4 && npm run test:stage5 && npm run test:stage6 && npm run test:stage7 && npm run test:stage8 && npm run test:stage9 && npm run test:stage9-idb && npm run test:stage10 && npm run test:stage10x && npm run test:stage11 && npm run test:stage12 && npm run test:stage13 && npm run test:stage14 && npm run test:stage15 && npm run test:stage16 && npm run test:stage18 && npm run test:stage19",
    "test:stage1": "node test/unit/markdown-renderer.test.mjs",
    "test:stage2": "node test/unit/content-blocks.test.mjs",
    "test:stage3": "node test/unit/base-url.test.mjs",
    "test:stage4": "node test/contracts/assets.test.mjs",
    "test:stage5": "node test/integration/pdf-ingestion.test.mjs",
    "test:stage6": "node test/integration/image-experience.test.mjs",
    "test:stage7": "node test/integration/mcp-rearm.test.mjs",
    "test:stage8": "node test/contracts/mcp-markdown-wire.test.mjs",
    "test:stage9": "node test/contracts/filesystem-store.test.mjs",
    "test:stage9-idb": "node test/contracts/indexeddb-store.test.mjs",
    "test:stage10": "node test/e2e/web-app.test.mjs",
    "test:stage10x": "node test/e2e/ui-primitives-browsers.test.mjs",
    "test:stage11": "node test/contracts/fetch-proxy-worker.test.mjs && node test/integration/web-ingestion.test.mjs",
    "test:stage12": "node test/integration/artifact-portability.test.mjs",
    "test:stage13": "node test/contracts/data-boundaries.test.mjs && node test/contracts/artifact-roundtrip.test.mjs",
    "test:stage14": "node test/unit/reducer.test.mjs",
    "test:stage15": "node test/contracts/compatibility-security.test.mjs",
    "test:stage16": "node test/performance/budgets.test.mjs",
    "test:stage18": "node test/integration/generation-lifecycle.test.mjs",
    "test:stage19": "node test/e2e/cross-host-journey.test.mjs",
    "test:packaging": "node test/packaging/install-smoke.test.mjs",
    "calibrate:budgets": "node test/support/calibrate-budgets.mjs",
    "eval": "node test/evals/run-eval.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "learning",
    "canvas",
    "claude-code",
    "codex",
    "agent"
  ],
  "bin": {
    "rabbithole-mcp": "./bin/mcp-server.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "marked": "^15.0.7",
    "pdfjs-dist": "^4.0.379",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^1.0.2"
  },
  "devDependencies": {
    "esbuild": "0.28.1",
    "fake-indexeddb": "^6.2.5",
    "playwright": "^1.61.1",
    "typescript": "5.9.3"
  }
}
