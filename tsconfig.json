    "src/core/contracts/generation.d.ts",
    "src/core/contracts/content.d.ts",
    "test/fixtures/contracts/artifact-fixture.js",
    "test/fixtures/contracts/store-fixture.js",
    "test/fixtures/contracts/engine-fixture.js",
